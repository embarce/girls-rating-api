# Server
APP_PORT=8080
APP_ENV=development

# 上传接口固定 API Key（维护脚本使用，通过 X-API-Key 请求头传递）
UPLOAD_API_KEY=your-upload-api-key-here

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=cat

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24
JWT_ISSUER=girls-rating-api

# Cloudflare R2 (S3 兼容)
R2_ACCOUNT_ID=id
R2_ACCESS_KEY=key
R2_SECRET_KEY=key
R2_BUCKET=image

# S3 公开访问 URL (用于拼接图片完整地址)
S3_HOST=https://image.com
